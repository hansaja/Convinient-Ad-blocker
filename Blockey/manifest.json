{
  "manifest_version": 3,
  "name": "Blockey",
  "description": "Blocks ads and helps you stay secure on the web",
  "version": "4.0.0",
  "icons": {
    "16": "icon.png",
    "128": "icons_128.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "options_page": "block.html",
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["youtube.js"]
    },
    {
      "matches": ["http://*/*"],
      "js": ["main.js"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_blocklist",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting",
    "alarms",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["options/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
